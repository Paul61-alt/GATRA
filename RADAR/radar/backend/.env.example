# ─── RADAR backend environment ───────────────────────────────────────────────
# Copy to `.env` and fill in. NEVER commit `.env` (it is gitignored).

# ── Required: API keys ───────────────────────────────────────────────────────
LINKUP_API_KEY=lp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx     # https://app.linkup.so
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxx                # https://console.anthropic.com
NOMINATIM_USER_AGENT=radar-dev (you@example.com)      # required by OSM Nominatim ToS — put a real contact

# ── Required in production: auth gate ────────────────────────────────────────
# Shared bearer token protecting all /scan* endpoints (they cost real money).
# Generate one: `openssl rand -hex 24`. If unset, the API fails closed (503).
RADAR_SHARED_TOKEN=
# Local dev escape hatch ONLY — set to 1 to disable auth when RADAR_SHARED_TOKEN is empty.
# Never enable this on a public deploy.
RADAR_ALLOW_NO_AUTH=

# ── Cost guards (have safe defaults — override to tune) ───────────────────────
# A full 15-competitor scan can cost ~€4.50 on Linkup. These caps stop runaway spend.
RADAR_DAILY_BUDGET_EUR=30        # hard daily ceiling across all scans (default 30)
RADAR_DAILY_HARD_CAP_EUR=8.0     # per-process hard cap (default 8.0)
RADAR_DAILY_WARN_CAP_EUR=5.0     # log a warning past this (default 5.0)
RADAR_BYOK_DAILY_SCAN_CAP=50     # max scans/day for bring-your-own-key testers (default 50)
RADAR_MAX_ENRICH=5               # competitors enriched per scan (default 5; 15 = full but pricey)
RADAR_MAX_CONCURRENT=2           # parallel scans (default 2)
RADAR_KILL_SWITCH=               # set to 1 to instantly block all paid calls

# ── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:8080   # extra origin allowed to call the API

# ── Optional: evals ──────────────────────────────────────────────────────────
BRAINTRUST_API_KEY=                  # only needed to run `braintrust eval ...`

# ── Optional: Supabase persistence (falls back to local JSON cache if absent) ─
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...service-role-key...
